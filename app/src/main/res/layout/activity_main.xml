<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0F0F">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- 타이틀 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="자동 전원 끄기"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:paddingTop="24dp"
            android:paddingBottom="6dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="화면이 꺼지면 타이머를 시작해요"
            android:textSize="14sp"
            android:textColor="#888888"
            android:gravity="center"
            android:paddingBottom="28dp" />

        <!-- 접근성 카드 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#1C1C1E"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:id="@+id/tvAccessibility"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="❌ 접근성 권한: 허용 필요"
                    android:textSize="14sp"
                    android:textColor="#DDDDDD"
                    android:paddingBottom="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAccessibility"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="접근성 권한 설정하러 가기"
                    android:textColor="#AAAAFF" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 시간 선택 카드 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#1C1C1E"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="화면 꺼지고 얼마 후 전원 끄기?"
                    android:textSize="15sp"
                    android:textColor="#CCCCCC"
                    android:paddingBottom="12dp" />

                <Spinner
                    android:id="@+id/spinnerDelay"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/spinner_bg"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textSize="16sp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ON/OFF 카드 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="#1C1C1E"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="18dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="자동 전원 끄기 사용"
                    android:textSize="16sp"
                    android:textColor="#FFFFFF" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchEnabled"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 저장 버튼 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="저장"
            android:textSize="17sp"
            android:layout_marginBottom="20dp" />

        <!-- 상태 표시 -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚫ 비활성화"
            android:textSize="14sp"
            android:textColor="#888888"
            android:gravity="center"
            android:lineSpacingExtra="4dp" />

    </LinearLayout>
</ScrollView>
